{
  "name": "brain-desktop",
  "productName": "Brain Desktop",
  "version": "1.0.0",
  "description": "Brain desktop workbench",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "prestart": "node ./scripts/prepare-start.js",
    "prepackage": "node ./scripts/prepare-start.js",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "node ./scripts/make-windows-nsis.js",
    "make:forge": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest --exclude src/main/make-windows-nsis.test.ts",
    "test:all": "vitest",
    "test:packaging": "vitest src/main/make-windows-nsis.test.ts"
  },
  "keywords": [],
  "author": {
    "name": "OpenClaw",
    "email": "openclaw@local"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "jsdom": "^29.0.2",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.7",
    "typescript": "~4.5.4",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
